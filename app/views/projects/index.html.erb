<h1><%= t('projects.index_title') %></h1>

<div id="projects">
  <% @projects.each do |project| %>
    <div style="border: 1px solid #ccc; padding: 15px; margin-bottom: 10px; border-radius: 5px;">
      <h2><%= project.title %></h2>
      <p><%= project.description %></p>
      <p><strong><%= t('projects.goal') %></strong> <%= number_to_currency(project.goal_amount, unit: project.base_currency + " ") %></p>
      <p><strong><%= t('projects.raised') %></strong> <%= number_to_currency(project.current_amount, unit: project.base_currency + " ") %></p>
      
      <%= link_to t('projects.view'), project_path(project) %>
    </div>
  <% end %>
</div>